<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Base: dark linear gradient background -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="@color/seamless_midnight"
                android:centerColor="@color/seamless_charcoal"
                android:endColor="@color/seamless_navy" />
            <corners android:radius="20dp" />
        </shape>
    </item>

    <!-- Subtle cyan glow at bottom center -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:centerX="0.5"
                android:centerY="0.85"
                android:gradientRadius="180"
                android:startColor="#2200D4AA"
                android:endColor="#00000000" />
            <corners android:radius="20dp" />
        </shape>
    </item>

    <!-- Thin semi-transparent violet border -->
    <item>
        <shape android:shape="rectangle">
            <stroke
                android:width="1dp"
                android:color="#337B61FF" />
            <corners android:radius="20dp" />
            <solid android:color="#00000000" />
        </shape>
    </item>

</layer-list>
